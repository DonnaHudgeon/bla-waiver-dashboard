# BLA Waiver Check-In Dashboard
# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to version control

# Rezdy Supplier API Key
# Find at: Rezdy dashboard > Settings > API Access
REZDY_API_KEY=your_rezdy_api_key_here

# Waiver Forever API Key
# Find at: WaiverForever web console > Account Settings > Integrations > API Key
WAIVERFOREVER_API_KEY=your_waiverforever_api_key_here

# Waiver Forever Template ID
# Find at: Your Zapier workflow config, or WaiverForever template > Settings tab > off-site signing link URL
WAIVERFOREVER_TEMPLATE_ID=your_template_id_here

# Simple access PIN for the dashboard (choose any 4-6 digit PIN)
DASHBOARD_PIN=1234
